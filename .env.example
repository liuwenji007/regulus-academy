# 模型提供商：deepseek | openai | openrouter | ollama | custom
LLM_PROVIDER=deepseek
LLM_API_KEY=
# LLM_BASE_URL=          # 只填域名前缀，不要带 /v1/chat/completions
# LLM_MODEL=

# 兼容旧变量（未设置 LLM_API_KEY 时生效）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

PORT=8080
# Docker 宿主机映射端口（install.sh 在 8080 被占用时会自动写入 HOST_PORT=8081 等）
# HOST_PORT=8080
DATABASE_PATH=./data/regulus.db
# 公网部署时可选：保护 LLM/Gateway 配置与用户删除等管理接口（Authorization: Bearer <token>）
# ADMIN_TOKEN=
# Docker 镜像内 Coach 资源目录（本地 go run 一般无需设置）
# REGULUS_COACH_ROOT=/app/regulus-coach
# 节点内多概念覆盖门槛（默认开启）；设为 0 关闭「未覆盖≥2 不点亮」
# REGULUS_STRICT_CONCEPT_COVERAGE=1
# 建树后 LLM 质检（默认开启）；设为 0 关闭 critique 重生成
# REGULUS_TREE_CRITIQUE=1
# 单次 LLM HTTP 超时（秒，默认 240）；慢速自定义 API 可调到 300～600
# REGULUS_LLM_TIMEOUT_SEC=240
# /domain/build、regenerate 整请求超时（秒，默认 360）
# REGULUS_DOMAIN_BUILD_TIMEOUT_SEC=360
# C1 导入：PDF 大小/页数、网页正文上限
# REGULUS_INGEST_MAX_PDF_BYTES=20971520
# REGULUS_INGEST_MAX_PDF_PAGES=200
# REGULUS_INGEST_MAX_PDF_CHARS=600000
# REGULUS_INGEST_MAX_URL_CHARS=80000
# REGULUS_INGEST_FETCH_TIMEOUT_SEC=15
# C2 纵深扩展：完成度解锁阈值（默认 0.8）
# REGULUS_EXTEND_MIN_RATIO=0.8

# IM Gateway（Telegram / 钉钉 / 飞书 / 企业微信）
GATEWAY_ENABLED=false
# 公网访问地址（用于展示 webhook 回调 URL，如 https://your.domain.com）
# GATEWAY_PUBLIC_URL=

# Telegram（Long Polling，无需公网）
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789

# 钉钉 Stream（WebSocket，无需公网）
# DINGTALK_CLIENT_ID = 开放平台 → 应用凭证 → AppKey（Client ID）
# DINGTALK_CLIENT_SECRET = AppSecret（Client Secret）
# 配置顺序：先启动服务 → 开放平台选 Stream 模式 → 点「验证 Stream 模式通道」
DINGTALK_ENABLED=true
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 飞书（默认 websocket 长连接，无需公网；webhook 模式需公网 HTTPS）
FEISHU_ENABLED=true
FEISHU_MODE=websocket
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# webhook 模式推荐：飞书开放平台 → 事件与回调 → Verification Token
# FEISHU_VERIFY_TOKEN=
# FEISHU_ALLOWED_USERS=ou_xxx,ou_yyy

# --- Langfuse 开发期追踪（默认关闭；仅本地 dev 建议开启，Docker/生产保持 false）---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Langfuse 根地址（Cloud 示例：EU https://cloud.langfuse.com，JP https://jp.cloud.langfuse.com）
# OTLP traces: {BASE_URL}/api/public/otel/v1/traces
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_ENVIRONMENT=development
# true：generation 记录 prompt/completion；false：仅元数据
LANGFUSE_LOG_CONTENT=true

# 企业微信（需公网 HTTPS 回调）
WECOM_ENABLED=false
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
# WECOM_ALLOWED_USERS=user1,user2
