# Railway Cloud Demo 环境变量模板（复制到 Railway Variables）

REGULUS_DEPLOYMENT=cloud
PORT=8080
DATABASE_PATH=/app/data/regulus.db

# 必填：平台 LLM（访客免费额度）
LLM_PROVIDER=deepseek
LLM_API_KEY=

# 必填：保护管理接口（openssl rand -hex 32）
ADMIN_TOKEN=

# Cloud 元数据（页脚链接）
REGULUS_CLOUD_GITHUB_URL=https://github.com/liuwenji007/regulus-academy
REGULUS_CLOUD_DOCS_URL=https://regulus-academy-docs.vercel.app
REGULUS_CLOUD_DEMO_URL=https://your-demo.up.railway.app

# 配额与限流
REGULUS_CLOUD_QUOTA_DAILY_MESSAGES=20
REGULUS_CLOUD_MAX_BUILD_JOBS_GLOBAL=3
REGULUS_CLOUD_RATE_LIMIT_PER_IP=60

# BYOK 密钥加密（openssl rand -hex 32）
REGULUS_CLOUD_ENCRYPTION_KEY=

# 安全：关闭 IM Gateway
GATEWAY_ENABLED=false

# Cloud 收紧 ingest / 建树
REGULUS_INGEST_MAX_PDF_BYTES=10485760
REGULUS_INGEST_MAX_PDF_PAGES=80
REGULUS_DOMAIN_BUILD_TIMEOUT_SEC=300
REGULUS_TREE_CRITIQUE=0
